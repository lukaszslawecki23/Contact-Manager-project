<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Contact_manager_app.Views.MainWindow"
        Width="1200"
        Height="800"
        Title="Contact Manager">
        
    <Grid Margin="50" RowDefinitions="Auto, Auto, *">
        <TextBlock Grid.Row="0" 
                   Text="Your Contact Manager" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   TextAlignment="Center" 
                   Margin="0,0,0,30"/>
            
        <StackPanel Grid.Row="1" 
                    Spacing="20" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,30">
            <Button x:Name="buttonnAddWindow" Content="Add contact" Click="ButtonnAdd_OnClick" />
            <Button x:Name="buttonnShow" Content="Show your contacts" Click="ButtonnShow_OnClick" />
        </StackPanel>
            
        <ContentControl Grid.Row="2" x:Name="AddingContactSpace"/>
        
    </Grid>
</Window>